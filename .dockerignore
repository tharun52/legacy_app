# Git
.git
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/

# Database files — handled by Docker volume
*.db
*.sqlite
*.sqlite3

# Environment files — never bake secrets into the image
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo

# Docs and markdown
*.md
README*

# Service files — not needed in container
*.service

# Logs
*.log
logs/
